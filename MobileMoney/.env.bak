#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'

#--------------------------------------------------------------------
# DATABASE (Configuration SQLite)
#--------------------------------------------------------------------
database.default.DBDriver = SQLite3
database.default.database = writable/database.sqlite
database.default.DBPrefix = 
database.default.port = 0
database.default.hostname = localhost
database.default.username = 
database.default.password = 
database.default.charset = UTF-8

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# Utilise le dossier 'writable/session' pour stocker les sessions
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = WRITEPATH . 'session'

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
# threshold 4 permet de tout enregistrer (utile pour déboguer les erreurs)
logger.threshold = 4